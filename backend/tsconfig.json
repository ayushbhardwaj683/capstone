{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@form-builder/shared": ["../packages/shared/src/index.ts"],
      "@form-builder/shared/*": ["../packages/shared/src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
